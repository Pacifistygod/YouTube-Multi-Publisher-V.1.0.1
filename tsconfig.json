{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "prisma/**/*.ts",
    "tests/phase1/**/*.ts",
    "tests/phase1/**/*.tsx",
    "vitest.config.ts"
  ],
  "references": [
    { "path": "sdk" }
  ]
}
